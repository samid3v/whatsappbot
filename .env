# Environment variables
NODE_ENV=development

# Bot settings
BOT_NAME=eFootball Bot
COMMAND_PREFIX=.
WARN_THRESHOLD=3
MUTE_DURATION_HOURS=2
MOBILE=true

# Allowed groups - comma separated group JIDs (leave empty for all groups)
# Example: ALLOWED_GROUPS=123456789-123456789@g.us,987654321-987654321@g.us
ALLOWED_GROUPS=
